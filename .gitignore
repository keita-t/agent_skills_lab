# ============================================================================
# .gitignore — 汎用テンプレート（OS / エディタ / 主要言語共通）
# ============================================================================

# ----------------------------------------------------------------------------
# OS生成ファイル
# ----------------------------------------------------------------------------
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ----------------------------------------------------------------------------
# エディタ・IDE
# ----------------------------------------------------------------------------
# Visual Studio Code
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
!.vscode/scripts/
!.vscode/scripts/**

# JetBrains (IntelliJ / PyCharm / WebStorm …)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
Session.vim

# Emacs
\#*\#
.\#*

# ----------------------------------------------------------------------------
# バックアップ・一時ファイル
# ----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
*.log
logs/

# ----------------------------------------------------------------------------
# 環境変数・機密情報
# ----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets.*

# ----------------------------------------------------------------------------
# ビルド成果物
# ----------------------------------------------------------------------------
dist/
build/
out/
target/

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage/
.hypothesis/
.tox/
.nox/
.mypy_cache/
dmypy.json

# ----------------------------------------------------------------------------
# アプリケーションローカルデータ
# ----------------------------------------------------------------------------
# SQLite DatabaseAdapter (DB_BACKEND=sqlite) のローカル DB ファイル
/data/
*.sqlite3
*.sqlite3-journal

# ----------------------------------------------------------------------------
# JavaScript / Node.js
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------------------------------------------------------------------
# Java / Kotlin / Scala
# ----------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear

# ----------------------------------------------------------------------------
# C / C++ / Rust
# ----------------------------------------------------------------------------
*.o
*.so
*.a
*.out
*.dSYM/
target/

# ----------------------------------------------------------------------------
# Go
# ----------------------------------------------------------------------------
*.exe
*.test
vendor/

# ----------------------------------------------------------------------------
# Ruby
# ----------------------------------------------------------------------------
.bundle/
vendor/bundle
