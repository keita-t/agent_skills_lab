{
  "version": "1",
  "namespace": "ecosystem",
  "tools": [
    {
      "name": "list_available",
      "title": "List available ecosystems",
      "description": "Return available ecosystem manifests and MCP exposure metadata from the source lab repository.",
      "handler": "ecosystem_catalog_service.list_available_ecosystems",
      "kind": "read",
      "risk_level": "low",
      "confirmation_mode": "none",
      "input_model": "ListAvailableEcosystemsInput",
      "result_model": "ListAvailableEcosystemsResult",
      "tags": ["catalog", "manifest"],
      "enabled_by_default": true,
      "dry_run_supported": false,
      "validators_after": [],
      "requires_repo_root": true,
      "requires_target_repo": false,
      "requires_ecosystem_slug": false,
      "supports_preview_token": false
    },
    {
      "name": "get_manifest",
      "title": "Get ecosystem manifest",
      "description": "Return the manifest summary, payload metadata, and MCP exposure details for one ecosystem.",
      "handler": "ecosystem_catalog_service.get_ecosystem_manifest",
      "kind": "read",
      "risk_level": "low",
      "confirmation_mode": "none",
      "input_model": "GetManifestInput",
      "result_model": "GetManifestResult",
      "tags": ["catalog", "manifest"],
      "enabled_by_default": true,
      "dry_run_supported": false,
      "validators_after": [],
      "requires_repo_root": true,
      "requires_target_repo": false,
      "requires_ecosystem_slug": true,
      "supports_preview_token": false
    },
    {
      "name": "preview_install",
      "title": "Preview ecosystem install",
      "description": "Build a side-effect-free install plan showing copy, update, and validator steps for one ecosystem.",
      "handler": "ecosystem_install_service.build_install_plan",
      "kind": "mutate",
      "risk_level": "low",
      "confirmation_mode": "none",
      "input_model": "PreviewInstallInput",
      "result_model": "PreviewInstallResult",
      "tags": ["install", "preview"],
      "enabled_by_default": true,
      "dry_run_supported": true,
      "validators_after": ["ecosystem.validate_registry"],
      "requires_repo_root": false,
      "requires_target_repo": true,
      "requires_ecosystem_slug": true,
      "supports_preview_token": true
    },
    {
      "name": "apply_install",
      "title": "Apply ecosystem install",
      "description": "Execute one ecosystem install after explicit confirmation and return validator results.",
      "handler": "ecosystem_install_service.execute_install",
      "kind": "mutate",
      "risk_level": "high",
      "confirmation_mode": "preview_token",
      "input_model": "ApplyInstallInput",
      "result_model": "ApplyInstallResult",
      "tags": ["install", "apply"],
      "enabled_by_default": true,
      "dry_run_supported": false,
      "validators_after": ["ecosystem.validate_registry"],
      "requires_repo_root": false,
      "requires_target_repo": true,
      "requires_ecosystem_slug": true,
      "supports_preview_token": true
    },
    {
      "name": "update_core_files",
      "title": "Update ecosystem core files",
      "description": "Render and apply the ecosystem-managed .github core files in a target repository.",
      "handler": "ecosystem_core_update_service.apply_core_file_updates",
      "kind": "mutate",
      "risk_level": "medium",
      "confirmation_mode": "none",
      "input_model": "UpdateCoreFilesInput",
      "result_model": "UpdateCoreFilesResult",
      "tags": ["update", "managed-files"],
      "enabled_by_default": true,
      "dry_run_supported": true,
      "validators_after": ["ecosystem.validate_registry"],
      "requires_repo_root": false,
      "requires_target_repo": true,
      "requires_ecosystem_slug": false,
      "supports_preview_token": false
    },
    {
      "name": "validate_registry",
      "title": "Validate ecosystem registry",
      "description": "Validate installed ecosystem manifests, membership metadata, and managed core file navigation.",
      "handler": "ecosystem_registry_validation_service.validate_registry",
      "kind": "read",
      "risk_level": "low",
      "confirmation_mode": "none",
      "input_model": "ValidateRegistryInput",
      "result_model": "ValidationResult",
      "tags": ["validate", "registry"],
      "enabled_by_default": true,
      "dry_run_supported": false,
      "validators_after": [],
      "requires_repo_root": true,
      "requires_target_repo": false,
      "requires_ecosystem_slug": false,
      "supports_preview_token": false
    }
  ]
}