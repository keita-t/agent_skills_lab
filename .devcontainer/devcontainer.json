{
  "name": "agent_skills_lab",
  "build": { "dockerfile": "Dockerfile" },
  "runArgs": ["--privileged"],
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker-host.sock,type=bind"
  ],
  "postCreateCommand": "python -m pip install --user -r requirements-dev.txt && command -v pytest && pytest --version",
  "postStartCommand": "bash .devcontainer/init-docker.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance"
      ]
    }
  }
}
